rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "johnbozorgi@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidRoom(data) {
      return data.hostId is string && 
             data.roomCode is string && 
             data.roomCode.size() == 5 &&
             data.name is string &&
             data.name.size() > 0 &&
             data.status in ['active', 'ended'] &&
             (!('vibe' in data) || data.vibe is string) &&
             (!('isAudioOnly' in data) || data.isAudioOnly is bool) &&
             (!('requiresApproval' in data) || data.requiresApproval is bool) &&
             (!('bannedUids' in data) || data.bannedUids is list);
    }

    function isValidPlaylist(data) {
      return data.uid is string && 
             data.name is string && 
             data.name.size() > 0 && 
             data.name.size() < 100 &&
             (!('isPublic' in data) || data.isPublic is bool);
    }

    function isValidPlaylistItem(data) {
      return data.youtubeId is string && 
             data.title is string && 
             data.title.size() < 200;
    }

    function isValidTrack(data) {
      return data.youtubeId is string && 
             data.title is string && 
             data.title.size() < 200 &&
             data.addedBy is string && 
             data.addedBy.size() < 50 &&
             data.sortOrder is number &&
             data.status in ['queued', 'playing', 'played'];
    }

    function isValidUserProfile(data) {
      return data.uid is string &&
             data.displayName is string &&
             data.username is string &&
             data.username.size() > 0 &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('rating' in data) || data.rating is number) &&
             (!('ratingCount' in data) || data.ratingCount is number) &&
             (!('followersCount' in data) || data.followersCount is number) &&
             (!('followingCount' in data) || data.followingCount is number);
    }

    function isValidRating(data) {
      return data.fromUid is string &&
             data.toUid is string &&
             data.score is number &&
             data.score >= 1 &&
             data.score <= 5;
    }

    function isValidFollow(data) {
      return data.followerUid is string &&
             data.followedUid is string &&
             data.followerUid == request.auth.uid;
    }

    function isValidNotification(data) {
      return data.toUid is string &&
             data.type in ["follow", "new_room", "new_music", "new_playlist"] &&
             data.message is string &&
             data.isRead is bool;
    }

    function isValidRoomJoinRequest(data) {
      return data.roomId is string &&
             data.uid is string &&
             data.status in ["pending", "approved", "rejected"];
    }

    function isValidRoomMember(data) {
      return data.roomId is string &&
             data.uid is string &&
             (!('isMuted' in data) || data.isMuted is bool);
    }

    function isValidRecommendation(data) {
      return data.youtubeId is string &&
             data.title is string &&
             data.uid is string;
    }

    function isBanned(roomId) {
      let roomDoc = get(/databases/$(database)/documents/rooms/$(roomId));
      return roomDoc != null && 'bannedUids' in roomDoc.data && request.auth.uid in roomDoc.data.bannedUids;
    }

    function isMuted(roomId) {
      let memberDoc = get(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid));
      return memberDoc != null && 'isMuted' in memberDoc.data && memberDoc.data.isMuted == true;
    }

    // Rooms
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRoom(request.resource.data) && request.resource.data.hostId == request.auth.uid;
      allow update: if isAuthenticated() && (
        (resource.data.hostId == request.auth.uid && isValidRoom(request.resource.data)) ||
        (!isBanned(roomId) && isValidRoom(request.resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['progress', 'isPlaying', 'currentTrackId'])) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.hostId == request.auth.uid);

      // Queue
      match /queue/{trackId} {
        allow read: if isAuthenticated() && !isBanned(roomId);
        allow create: if isAuthenticated() && !isBanned(roomId) && !isMuted(roomId) && isValidTrack(request.resource.data);
        allow update: if isAuthenticated() && (
          // Host can update status (queued -> playing -> played)
          (get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid && isValidTrack(request.resource.data)) ||
          // Guests can't update tracks for now, maybe only their own?
          (!isBanned(roomId) && !isMuted(roomId) && request.resource.data.addedByUid == request.auth.uid && isValidTrack(request.resource.data))
        );
        allow delete: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid);
      }

      // Join Requests
      match /requests/{requestId} {
        allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid);
        allow create: if isAuthenticated() && !isBanned(roomId) && request.resource.data.uid == request.auth.uid && isValidRoomJoinRequest(request.resource.data);
        allow update: if isAuthenticated() && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid && isValidRoomJoinRequest(request.resource.data);
        allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid);
      }

      // Members
      match /members/{memberId} {
        allow read: if isAuthenticated() && !isBanned(roomId);
        allow create: if isAuthenticated() && !isBanned(roomId) && request.resource.data.uid == request.auth.uid && isValidRoomMember(request.resource.data);
        allow update: if isAuthenticated() && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid && isValidRoomMember(request.resource.data);
        allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid);
      }
    }

    // Recommendations
    match /recommendations/{recommendationId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidRecommendation(request.resource.data);
      allow update: if false;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Play History
    match /play_history/{playId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Playlists
    match /playlists/{playlistId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || resource.data.isPublic == true);
      allow create: if isAuthenticated() && isValidPlaylist(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isOwner(resource.data.uid) && isValidPlaylist(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.uid);

      match /items/{itemId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/playlists/$(playlistId)).data.uid == request.auth.uid || get(/databases/$(database)/documents/playlists/$(playlistId)).data.isPublic == true);
        allow create: if isAuthenticated() && get(/databases/$(database)/documents/playlists/$(playlistId)).data.uid == request.auth.uid && isValidPlaylistItem(request.resource.data);
        allow update: if isAuthenticated() && get(/databases/$(database)/documents/playlists/$(playlistId)).data.uid == request.auth.uid && isValidPlaylistItem(request.resource.data);
        allow delete: if isAuthenticated() && get(/databases/$(database)/documents/playlists/$(playlistId)).data.uid == request.auth.uid;
      }
    }

    // Users
    match /users/{userId} {
      allow read: if true; // Public profiles
      allow create: if isAuthenticated() && userId == request.auth.uid && isValidUserProfile(request.resource.data);
      allow update: if isAuthenticated() && (
        (userId == request.auth.uid && isValidUserProfile(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'ratingCount', 'followersCount', 'followingCount', 'songsAddedCount', 'roomsJoinedCount'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ratings
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidRating(request.resource.data) && request.resource.data.fromUid == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Follows
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidFollow(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.followerUid == request.auth.uid;
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.toUid == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.toUid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAuthenticated() && resource.data.toUid == request.auth.uid;
    }

    // User Settings
    match /userSettings/{userId} {
      allow read: if isAuthenticated() && userId == request.auth.uid;
      allow create: if isAuthenticated() && userId == request.auth.uid;
      allow update: if isAuthenticated() && userId == request.auth.uid;
    }
  }
}
